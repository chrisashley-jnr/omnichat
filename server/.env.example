PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379

# Cloudflare Turnstile CAPTCHA
# Get keys from https://dash.cloudflare.com → Turnstile
# Leave empty to disable CAPTCHA enforcement (dev mode)
TURNSTILE_SECRET_KEY=

# Rate limiting on find-partner
FIND_PARTNER_RATE_MAX=10
FIND_PARTNER_RATE_WINDOW=60

# Ban threshold (number of reports before auto-ban)
BAN_THRESHOLD=5

# TURN server credentials (works with coturn or any static-credential provider)
# Example: TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Geoblocking — comma-separated ISO 3166-1 alpha-2 country codes
# Leave empty to disable (no countries blocked). Populate only after legal review.
GEOBLOCK_COUNTRIES=

# Ads
AD_PROVIDER=adsense
AD_UNIT_PRECHAT=REPLACE_WITH_AD_UNIT_ID
AD_UNIT_SIDEBAR=REPLACE_WITH_AD_UNIT_ID
AD_UNIT_INTERSTITIAL=REPLACE_WITH_AD_UNIT_ID
